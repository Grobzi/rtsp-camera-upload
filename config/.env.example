# SFTP server
SFTP_HOST=example.com
SFTP_PORT=22
SFTP_USER=uploader
# Use either SFTP_PRIVATE_KEY (path to private key) or SFTP_PASSWORD
SFTP_PRIVATE_KEY=/home/pi/.ssh/uploader_key
#SFTP_PASSWORD=your_password_here

# Local copy retention (optional). If set, script will save timestamped images locally.
#OUTPUT_DIR=/var/local/camera_snapshots

# Run mode: if INTERVAL_SECONDS is set, the script will run continuously
# and capture+upload each camera every INTERVAL_SECONDS seconds. If empty,
# run-once behavior (suitable for cron) is used.
#INTERVAL_SECONDS=300

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG
