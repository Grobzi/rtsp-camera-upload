# FTPS (FTPES / explicit FTPS) configuration
FTPS_HOST=YOUR_FTPS_HOST_HERE
# FTPS default port for explicit FTPS (FTPES) is 21
FTPS_PORT=21
# The server certificate is issued for a2eb2.netcup.net, not the full hostname
FTPS_TLS_HOSTNAME=YOUR_TLS_HOSTNAME_HERE
FTPS_USER=FTP_USER_HERE
# Provide password or leave commented if not used
FTPS_PASSWORD=YOUR_PASSWORD_HERE
# Optional: path to CA bundle to validate the server certificate
#FTPS_CAFILE=/etc/ssl/certs/ca-bundle.crt

# Local copy retention (optional). If set, script will save timestamped images locally.
#OUTPUT_DIR=/var/local/camera_snapshots

# Run mode: if INTERVAL_SECONDS is set, the script will run continuously
# and capture+upload each camera every INTERVAL_SECONDS seconds. If empty,
# run-once behavior (suitable for cron) is used.
#INTERVAL_SECONDS=300

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG
FFMPEG_CMD=ffmpeg.exe
